# 이 파일을 복사해 .env 로 만들고 실제 키를 채웁니다: cp .env.example .env
# .env 는 .gitignore 로 커밋 차단됨. 실제 키는 절대 커밋 금지.

# Gemini / Veo API 키 (발급: https://aistudio.google.com/apikey)
# - 영상 생성(Veo) + 텍스트 폴백에 사용
GEMINI_API_KEY=

# Claude API 키 (발급: https://console.anthropic.com/settings/keys)
# - 훅·카피 등 고부가 텍스트 우선 생성(없으면 Gemini→템플릿 폴백). 영상엔 사용 안 함
ANTHROPIC_API_KEY=
