# 이 파일을 복사해서 .env 로 만들고 실제 키를 채우세요.
#   cp .env.example .env  &&  chmod 600 .env
# .env 는 .gitignore 에 등록되어 있어 커밋되지 않습니다. 절대 키를 공유하지 마세요.
#
# 시세 조회/백테스트에는 키가 필요 없습니다. 아래는 실거래(--live)부터 사용.

# --- 업비트 실거래 키 (PC 웹에서 발급, '출금' 권한은 절대 켜지 마세요) ---
UPBIT_ACCESS_KEY=your-access-key-here
UPBIT_SECRET_KEY=your-secret-key-here

# --- 텔레그램 알림/하트비트 (선택, 권장) ---
# 1) @BotFather 에게 /newbot → 토큰 받기
# 2) 만든 봇과 대화 시작 후 @userinfobot 에게 내 chat id 받기
# 없으면 알림 기능만 꺼지고 봇은 정상 동작합니다.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# (선택) 라이브 대시보드를 GitHub Pages에 게시하려면 — 저장소 contents 쓰기 권한 토큰
# 없으면 게시는 건너뜀(텔레그램 대시보드는 정상). 공개 저장소이므로 민감정보는 게시 안 함.
GITHUB_TOKEN=
GITHUB_REPO=jtaechul/Product
GITHUB_PAGES_BRANCH=main
